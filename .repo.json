{
  "todosExist": false,
  "exec": [
    "touch .env",
    "touch .envrc",
    "td init",
    "chmod +x ./scripts/dg.sh",
    "chmod +x ./.rulesync/hooks/init.sh",
    "rulesync generate"
  ],
  "info": ".todo directory initialized, ai config's generated. use 'npx skills' cli to add skills.",
  "open": [
    "zeditor .",
    "codex",
    "claude",
    "lazygit"
  ]
}
